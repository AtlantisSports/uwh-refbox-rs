{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Pre-commit checks",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "./scripts/pre-commit-checks.ps1"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": [
                "$rustc",
                {
                    "owner": "clippy",
                    "fileLocation": "absolute",
                    "pattern": {
                        "regexp": "^(warning|error)(?:\\[([^\\]]+)\\])?: (.*)$",
                        "severity": 1,
                        "code": 2,
                        "message": 3
                    }
                }
            ]
        },
        {
            "label": "Smart commit",
            "type": "shell", 
            "command": "pwsh",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "./scripts/commit.ps1",
                "${input:commitMessage}"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "Format code",
            "type": "shell",
            "command": "cargo",
            "args": ["fmt"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Clippy check",
            "type": "shell", 
            "command": "cargo",
            "args": ["clippy"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [
                "$rustc"
            ]
        }
    ],
    "inputs": [
        {
            "id": "commitMessage",
            "description": "Enter commit message",
            "default": "",
            "type": "promptString"
        }
    ]
}
